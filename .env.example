PORT=3000
SESSION_SECRET=troque-por-uma-chave-grande-e-aleatoria-com-32-caracteres-ou-mais

# Defina esta variável em produção para ativar PostgreSQL.
# Exemplo: postgres://usuario:senha@host:5432/banco
DATABASE_URL=

# Em produção pública, use browser para o CSV baixar no navegador.
# No PC local, use local para salvar em C:\Users\<usuario>\Downloads.
DOWNLOAD_MODE=browser

# Credenciais do aplicativo criado no Bling. O usuario final nao preenche isso;
# ele apenas autoriza o app na aba Perfil.
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
# Precisa ser igual ao Link de redirecionamento cadastrado no app do Bling.
# Local: http://localhost:3000/api/integrations/bling/callback
# Producao: https://seu-dominio.com/api/integrations/bling/callback
BLING_REDIRECT_URI=

# Nome exato do deposito no Bling usado na planilha de entrada de estoque.
BLING_STOCK_DEPOSIT=Depósito Geral

# Use true via NODE_ENV=production no provedor.
NODE_ENV=production

# No PC local usando http://localhost, pode sobrescrever para false no .env real.
# COOKIE_SECURE=false

# Em provedores com SSL gerenciado, mantenha vazio.
# Para Postgres sem SSL, como o banco remoto atual: PGSSL=false
PGSSL=
